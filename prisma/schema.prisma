datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model EdisiJurnal {
  id           String      @id @default(uuid())
  volume       Int         
  nomor        Int         
  bulan        String      
  tahun        Int         
  isAktif      Boolean     @default(true) 
  createdAt    DateTime    @default(now())
  naskah       Naskah[]
  pengajuan    PengajuanDana[]
}

model PengaturanTarif {
  id                String   @id @default(uuid())
  honorEditor       Float    
  honorReviewer     Float    
  persentasePajak   Float    @default(2.5) 
  updatedAt         DateTime @updatedAt
}

model Editor {
  id           String   @id @default(uuid())
  nama         String
  nidn         String?  
  noRekening   String
  namaBank     String
  npwp         String?
  createdAt    DateTime @default(now())
  naskah       Naskah[]
}

model Reviewer {
  id           String   @id @default(uuid())
  nama         String
  institusi    String   
  noRekening   String
  namaBank     String
  npwp         String?
  createdAt    DateTime @default(now())
  naskah       Naskah[]
}

model Naskah {
  id            String       @id @default(uuid())
  judul         String
  author        String       
  edisiId       String
  edisiJurnal   EdisiJurnal  @relation(fields: [edisiId], references: [id])
  editorId      String
  editor        Editor       @relation(fields: [editorId], references: [id])
  reviewerId    String
  reviewer      Reviewer     @relation(fields: [reviewerId], references: [id])
  createdAt     DateTime     @default(now())
}

model PengajuanDana {
  id              String       @id @default(uuid())
  tanggalPengajuan DateTime    @default(now())
  edisiId         String       @unique 
  edisiJurnal     EdisiJurnal  @relation(fields: [edisiId], references: [id])
  totalHonorBruto Float
  totalPotonganPajak Float
  totalHonorNetto  Float
  status          String       @default("PENDING")
  catatanRevisi   String?      
  tandaTanganKaprodi String?   
  updatedAt       DateTime     @updatedAt
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   
  role      String   
}