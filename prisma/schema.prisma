datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model SystemSetting {
  id              String          @id @default(uuid())
  volume          Int
  no              Int
  bulan           String
  tahun           Int
  honorEditor     Float
  honorReviewer   Float
  taxRate         Float           @default(2.5)
  isActive        Boolean         @default(true)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  naskahJurnals   NaskahJurnal[]
  pengajuanDana   PengajuanDana?
}

model Editor {
  id           String          @id @default(uuid())
  nama         String
  nidn         String?
  noRekening   String
  namaBank     String
  npwp         String?
  
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  
  naskah       NaskahJurnal[]
}

model Reviewer {
  id           String          @id @default(uuid())
  nama         String
  institusi    String
  noRekening   String
  namaBank     String
  npwp         String?
  
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  
  naskah       NaskahJurnal[]
}

model NaskahJurnal {
  id              String         @id @default(uuid())
  title           String
  author          String
  
  systemSettingId String
  systemSetting   SystemSetting  @relation(fields: [systemSettingId], references: [id])
  
  editorId        String
  editor          Editor         @relation(fields: [editorId], references: [id])
  
  reviewerId      String
  reviewer        Reviewer       @relation(fields: [reviewerId], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PengajuanDana {
  id                 String         @id @default(uuid())
  
  systemSettingId    String         @unique
  systemSetting      SystemSetting  @relation(fields: [systemSettingId], references: [id])
  
  status             String         @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason    String?
  digitalSignature   String?
  
  totalHonorBruto    Float
  totalTax           Float
  totalHonorNetto    Float
  
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  password   String
  nama       String
  role       String   // ADMIN, EDITOR, REVIEWER, KAPRODI
  editorId   String?
  reviewerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}